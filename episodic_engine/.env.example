# Episodic Intelligence Engine — Environment Variables
# Copy this to .env and fill in your values

# ── LLM Configuration ─────────────────────────────────────────
# OpenAI-compatible endpoint (default: OpenAI)
LLM_BASE_URL=https://api.openai.com/v1

# Your API key
LLM_API_KEY=sk-YOUR_KEY_HERE

# Model to use (any OpenAI-compatible model name)
LLM_MODEL=gpt-4o-mini

# ── Server Configuration ───────────────────────────────────────
# Host and port for the FastAPI server
HOST=0.0.0.0
PORT=8000
